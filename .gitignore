# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
env/
.env

# Data — do not commit raw videos or processed frames
data/processed/
data/frames/
data/videos/

# Checkpoints — large binary files; track only manually
checkpoints/*.pt
checkpoints/*.pth
!checkpoints/.gitkeep

# Logs
logs/
runs/
wandb/
*.tfevents.*

# Results — commit the final markdown table, not intermediate CSVs
results/*.csv
!results/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
